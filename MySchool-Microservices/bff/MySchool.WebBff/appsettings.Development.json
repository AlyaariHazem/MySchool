{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "https://localhost:4200" ]
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    }
  },
  "IdentityService": {
    "GrpcUrl": "http://localhost:8083"
  },
  "OpenApi": {
    "Services": {
      "backend": "http://localhost:5000"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "backend": {
        "Destinations": {
          "backend": {
            "Address": "http://localhost:5000/"
          }
        }
      }
    }
  }
}
